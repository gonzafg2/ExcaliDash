{
  "realm": "excalidash",
  "enabled": true,
  "displayName": "ExcaliDash Local",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "clients": [
    {
      "clientId": "excalidash-local",
      "name": "ExcaliDash Local",
      "description": "Local OIDC test client for ExcaliDash",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:16767/api/auth/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:16767"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Example",
      "email": "alice@example.com",
      "requiredActions": ["UPDATE_PASSWORD"]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Example",
      "email": "bob@example.com",
      "requiredActions": ["UPDATE_PASSWORD"]
    }
  ]
}
